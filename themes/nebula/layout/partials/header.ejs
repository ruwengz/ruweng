<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= theme.site_description || config.description %>">
  <title><%= page.title ? page.title + ' - ' : '' %><%= config.title %></title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet">
  
  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <!-- Main Styles -->
  <%- css('css/main') %>
</head>
<body>
  
  <!-- Header -->
  <header class="site-header glass">
    <div class="container">
      <nav class="header-nav">
        <a href="/" class="logo-link">
          <span class="logo-icon">💻</span>
          <span class="logo-text"><%= theme.site_name %></span>
        </a>
        
        <ul class="nav-list">
          <% var currentPath = page.path || ''; %>
          <% Object.keys(theme.menu).forEach(function(key) { %>
            <% var menuPath = theme.menu[key]; %>
            <% var isActive = currentPath.indexOf(menuPath.replace('/', '')) === 0 || 
                             (menuPath === '/' && (currentPath === '' || currentPath === 'index.html')); %>
            <li class="nav-item <%= isActive ? 'active' : '' %>">
              <a href="<%- url_for(menuPath) %>"><%= key %></a>
            </li>
          <% }); %>
        </ul>
        
        <div class="header-actions">
          <button class="theme-toggle" title="切换主题">
            <i class="fas fa-moon"></i>
          </button>
          <button class="search-toggle" title="搜索">
            <i class="fas fa-search"></i>
          </button>
        </div>
      </nav>
    </div>
  </header>

  <style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 15px 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .header-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #f0f6fc;
    text-decoration: none;
  }

  .logo-icon {
    font-size: 1.8rem;
  }

  .logo-text {
    font-size: 1.3rem;
    font-weight: 700;
    background: linear-gradient(135deg, #58a6ff, #a855f7);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-list {
    display: flex;
    gap: 5px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-item a {
    display: block;
    padding: 10px 18px;
    color: #8b949e;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.95rem;
    transition: all 0.3s ease;
  }

  .nav-item:hover a,
  .nav-item.active a {
    color: #f0f6fc;
    background: rgba(88, 166, 255, 0.1);
  }

  .header-actions {
    display: flex;
    gap: 10px;
  }

  .header-actions button {
    width: 40px;
    height: 40px;
    border: none;
    background: rgba(255,255,255,0.05);
    border-radius: 8px;
    color: #8b949e;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .header-actions button:hover {
    background: rgba(88, 166, 255, 0.15);
    color: #58a6ff;
  }

  @media (max-width: 768px) {
    .nav-list {
      display: none;
    }
  }
  </style>
