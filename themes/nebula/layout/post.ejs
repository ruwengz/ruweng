<%- include('partials/header') %>

<!-- 背景动效 -->
<div class="bg-animation"></div>
<div class="grid-overlay"></div>

<div class="container">
  <div class="main-layout">
    
    <!-- 左侧边栏 -->
    <aside class="sidebar-left">
      <%- include('partials/sidebar-left') %>
    </aside>
    
    <!-- 文章内容 -->
    <main class="main-content article-page">
      <article class="post-article">
        <header class="post-header">
          <div class="post-meta-top">
            <% if (page.categories && page.categories.length) { %>
              <% page.categories.forEach(function(cat) { %>
                <a href="<%- url_for(cat.path) %>" class="post-category"><%= cat.name %></a>
              <% }); %>
            <% } else { %>
              <span class="post-category">技术</span>
            <% } %>
            <span class="post-date"><%= date(page.date, 'YYYY-MM-DD') %></span>
          </div>
          <h1 class="post-title"><%= page.title %></h1>
          <div class="post-meta">
            <span class="post-author">
              <span class="author-avatar">👨‍💻</span>
              <%= config.author %>
            </span>
            <span class="post-views">👁 <%= page.views || 0 %></span>
            <span class="post-comments">💬 <%= page.comments || 0 %></span>
            <span class="post-time">⏱ <%= page.reading_time || 5 %> 分钟</span>
          </div>
        </header>
        
        <% if (page.thumbnail) { %>
          <div class="post-thumbnail">
            <img src="<%= page.thumbnail %>" alt="<%= page.title %>">
          </div>
        <% } %>
        
        <div class="post-content">
          <%- page.content %>
        </div>
        
        <footer class="post-footer">
          <div class="post-tags">
            <% if (page.tags && page.tags.length) { %>
              <% page.tags.forEach(function(tag) { %>
                <a href="<%- url_for(tag.path) %>" class="post-tag"># <%= tag.name %></a>
              <% }); %>
            <% } %>
          </div>
          
          <div class="post-share">
            <span class="share-label">分享到:</span>
            <button class="share-btn" data-platform="weibo" title="分享到微博">
              <i class="fab fa-weibo"></i>
            </button>
            <button class="share-btn" data-platform="twitter" title="分享到 Twitter">
              <i class="fab fa-twitter"></i>
            </button>
            <button class="share-btn" data-platform="copy" title="复制链接">
              <i class="fas fa-link"></i>
            </button>
          </div>
        </footer>
      </article>
      
      <!-- 相关文章 -->
      <div class="related-posts">
        <h3 class="related-title">📚 相关推荐</h3>
        <div class="related-grid">
          <% site.posts.sort({date: -1}).limit(3).forEach(function(post) { %>
            <% if (post.path !== page.path) { %>
              <a href="<%- url_for(post.path) %>" class="related-card">
                <div class="related-image" style="background: linear-gradient(135deg, #58a6ff33, #a855f733);">
                  📄
                </div>
                <div class="related-info">
                  <span class="related-date"><%= date(post.date, 'YYYY-MM-DD') %></span>
                  <span class="related-title"><%= post.title %></span>
                </div>
              </a>
            <% } %>
          <% }); %>
        </div>
      </div>
      
      <!-- 评论区域 -->
      <div class="comments-section">
        <h3 class="comments-title">💬 留言讨论</h3>
        <div id="comments"></div>
      </div>
    </main>
    
    <!-- 右侧边栏 -->
    <aside class="sidebar-right">
      <%- include('partials/sidebar-right') %>
    </aside>
    
  </div>
</div>

<%- include('partials/footer') %>

<style>
/* 文章页样式 */
.article-page {
  padding-top: 20px;
}

.post-article {
  background: #1e2530;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  overflow: hidden;
}

.post-header {
  padding: 30px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.post-meta-top {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 15px;
}

.post-category {
  padding: 5px 12px;
  background: rgba(88, 166, 255, 0.15);
  color: #58a6ff;
  border-radius: 15px;
  font-size: 0.8rem;
}

.post-date {
  color: #6e7681;
  font-size: 0.85rem;
}

.post-title {
  font-size: 2rem;
  font-weight: 700;
  color: #f0f6fc;
  margin-bottom: 20px;
  line-height: 1.4;
}

.post-meta {
  display: flex;
  gap: 20px;
  font-size: 0.85rem;
  color: #8b949e;
}

.post-author {
  display: flex;
  align-items: center;
  gap: 8px;
}

.author-avatar {
  font-size: 1.2rem;
}

.post-thumbnail {
  width: 100%;
  max-height: 400px;
  overflow: hidden;
}

.post-thumbnail img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.post-content {
  padding: 30px;
  color: #c9d1d9;
  line-height: 1.8;
  font-size: 1rem;
}

.post-content h2 {
  color: #f0f6fc;
  font-size: 1.5rem;
  margin: 30px 0 15px;
  padding-left: 15px;
  border-left: 4px solid #58a6ff;
}

.post-content h3 {
  color: #f0f6fc;
  font-size: 1.25rem;
  margin: 25px 0 12px;
}

.post-content p {
  margin-bottom: 15px;
}

.post-content code {
  background: #0d1117;
  padding: 2px 6px;
  border-radius: 4px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.9em;
  color: #ff7b72;
}

.post-content pre {
  background: #0d1117;
  padding: 20px;
  border-radius: 8px;
  overflow-x: auto;
  margin: 20px 0;
}

.post-content pre code {
  background: none;
  padding: 0;
  color: #c9d1d9;
}

.post-content blockquote {
  border-left: 4px solid #a855f7;
  padding: 15px 20px;
  margin: 20px 0;
  background: rgba(168, 85, 247, 0.1);
  border-radius: 0 8px 8px 0;
  color: #8b949e;
}

.post-content img {
  max-width: 100%;
  border-radius: 8px;
  margin: 20px 0;
}

.post-content a {
  color: #58a6ff;
  text-decoration: underline;
}

.post-content ul, .post-content ol {
  margin: 15px 0;
  padding-left: 25px;
}

.post-content li {
  margin-bottom: 8px;
}

.post-footer {
  padding: 25px 30px;
  border-top: 1px solid rgba(255,255,255,0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 15px;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.post-tag {
  padding: 5px 12px;
  background: #161b22;
  color: #8b949e;
  border-radius: 15px;
  font-size: 0.8rem;
  transition: all 0.3s ease;
}

.post-tag:hover {
  background: rgba(88, 166, 255, 0.15);
  color: #58a6ff;
}

.post-share {
  display: flex;
  align-items: center;
  gap: 10px;
}

.share-label {
  color: #6e7681;
  font-size: 0.85rem;
}

.share-btn {
  width: 36px;
  height: 36px;
  border: none;
  background: #161b22;
  border-radius: 50%;
  color: #8b949e;
  cursor: pointer;
  transition: all 0.3s ease;
}

.share-btn:hover {
  background: #58a6ff;
  color: white;
  transform: translateY(-3px);
}

.related-posts {
  margin-top: 30px;
}

.related-title {
  font-size: 1.1rem;
  color: #f0f6fc;
  margin-bottom: 20px;
}

.related-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.related-card {
  background: #1e2530;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.1);
  transition: all 0.3s ease;
}

.related-card:hover {
  transform: translateY(-5px);
  border-color: rgba(88, 166, 255, 0.3);
}

.related-image {
  height: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
}

.related-info {
  padding: 15px;
}

.related-date {
  font-size: 0.75rem;
  color: #6e7681;
  display: block;
  margin-bottom: 8px;
}

.related-title {
  font-size: 0.9rem;
  color: #c9d1d9;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.comments-section {
  margin-top: 40px;
}

.comments-title {
  font-size: 1.1rem;
  color: #f0f6fc;
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

@media (max-width: 768px) {
  .related-grid {
    grid-template-columns: 1fr;
  }
  
  .post-title {
    font-size: 1.5rem;
  }
  
  .post-meta {
    flex-wrap: wrap;
    gap: 10px;
  }
}
</style>
