<%- include('partials/header') %>

<!-- 背景动效 -->
<div class="bg-animation"></div>
<div class="grid-overlay"></div>

<div class="container">
  <div class="main-layout">
    
    <!-- 左侧边栏 -->
    <aside class="sidebar-left">
      <%- include('partials/sidebar-left') %>
    </aside>
    
    <!-- 主内容区 -->
    <main class="main-content">
      
      <!-- Banner -->
      <div class="banner">
        <div class="banner-overlay"></div>
        <div class="banner-content">
          <h1 class="banner-title">探索技术的无限可能</h1>
          <p class="banner-subtitle">分享前端开发、人工智能、云计算等技术领域的最新资讯与实战经验</p>
        </div>
      </div>
      
      <!-- 分类筛选 -->
      <div class="filter-tags">
        <span class="filter-tag active">全部</span>
        <span class="filter-tag">前端开发</span>
        <span class="filter-tag">后端技术</span>
        <span class="filter-tag">人工智能</span>
        <span class="filter-tag">云计算</span>
        <span class="filter-tag">开源项目</span>
        <span class="filter-tag">工具推荐</span>
        <span class="filter-tag">经验分享</span>
      </div>
      
      <!-- 文章列表 -->
      <div class="article-list">
        <% page.posts.forEach(function(post) { %>
          <article class="article-card">
            <% if (post.thumbnail) { %>
              <img src="<%= post.thumbnail %>" alt="<%= post.title %>" class="article-image">
            <% } else { %>
              <div class="article-image" style="background: linear-gradient(135deg, #58a6ff33, #a855f733); display: flex; align-items: center; justify-content: center; font-size: 3rem;">📄</div>
            <% } %>
            <div class="article-content">
              <div class="article-meta">
                <span class="article-date"><%= date(post.date, 'YYYY-MM-DD') %></span>
                <% if (post.categories && post.categories.length) { %>
                  <span class="article-category"><%= post.categories.data[0].name %></span>
                <% } else { %>
                  <span class="article-category">技术</span>
                <% } %>
              </div>
              <h2 class="article-title">
                <a href="<%- url_for(post.path) %>"><%= post.title %></a>
              </h2>
              <p class="article-excerpt"><%= strip_html(post.excerpt || post.description || '').substring(0, 150) %>...</p>
              <div class="article-footer">
                <div class="article-stats">
                  <span>👁 <%= post.views || Math.floor(Math.random() * 1000) %></span>
                  <span>💬 <%= post.comments || Math.floor(Math.random() * 50) %></span>
                  <span>⏱ <%= post.reading_time || '5' %> 分钟</span>
                </div>
                <a href="<%- url_for(post.path) %>" class="read-more">阅读原文 →</a>
              </div>
            </div>
          </article>
        <% }); %>
      </div>
      
      <!-- 分页 -->
      <% if (page.total > 1) { %>
        <nav class="pagination">
          <% if (page.prev) { %>
            <a href="<%- url_for(page.prev_link) %>" class="page-link">← 上一页</a>
          <% } %>
          <span class="page-info"><%= page.current %> / <%= page.total %></span>
          <% if (page.next) { %>
            <a href="<%- url_for(page.next_link) %>" class="page-link">下一页 →</a>
          <% } %>
        </nav>
      <% } %>
      
    </main>
    
    <!-- 右侧边栏 -->
    <aside class="sidebar-right">
      <%- include('partials/sidebar-right') %>
    </aside>
    
  </div>
</div>

<%- include('partials/footer') %>

<style>
/* 首页样式补充 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20px;
  margin-top: 40px;
  padding: 20px;
}

.page-link {
  padding: 10px 20px;
  background: #1e2530;
  border-radius: 8px;
  color: #8b949e;
  transition: all 0.3s ease;
}

.page-link:hover {
  background: #58a6ff;
  color: #0d1117;
}

.page-info {
  color: #6e7681;
  font-size: 0.9rem;
}

.back-to-top {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 50px;
  height: 50px;
  border: none;
  background: linear-gradient(135deg, #58a6ff, #a855f7);
  border-radius: 50%;
  color: white;
  font-size: 1.2rem;
  cursor: pointer;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
  box-shadow: 0 4px 20px rgba(88, 166, 255, 0.3);
}

.back-to-top.show {
  opacity: 1;
  visibility: visible;
}

.back-to-top:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 30px rgba(88, 166, 255, 0.4);
}

.reading-progress {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: rgba(255,255,255,0.1);
  z-index: 1001;
}

.reading-progress .progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #58a6ff, #a855f7);
  width: 0%;
  transition: width 0.1s ease;
}
</style>
